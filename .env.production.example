# === Render (백엔드) 환경변수 ===

# Neon에서 발급받은 PostgreSQL 연결 문자열
# asyncpg 드라이버 사용 (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/aioj?sslmode=require

# Upstash에서 발급받은 Redis 연결 문자열
REDIS_URL=rediss://default:password@us1-xxx.upstash.io:6380

# JWT 시크릿 (Render가 자동 생성, 또는 직접 입력)
JWT_SECRET=your-strong-random-secret-here

# CORS: Vercel 배포 URL로 교체
BACKEND_CORS_ORIGINS=["https://aioj.vercel.app"]

DEBUG=false


# === Vercel (프론트엔드) 환경변수 ===

# Render 백엔드 URL
NEXT_PUBLIC_API_URL=https://aioj-backend.onrender.com
